# pandas_write_safety.rules
# Technology: pandas | Capability: write

rule pandas-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "pd.eval("
  MESSAGE "Blocked an unsafe pattern in pandas. Use the recommended best practices for 2025/2026."
}

rule pandas-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "Panel"
  MESSAGE "You are using an outdated API for pandas. Please upgrade to the newer API."
}
